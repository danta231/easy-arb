# easy-arb 云服务器常驻运行环境模板。
# 中文说明：复制到 /etc/easy-arb/easy-arb-live.env 后再按服务器路径调整。
# 本文件只放非凭证运行参数；账户密钥、私钥、token（令牌）等凭证放到
# /etc/easy-arb/easy-arb-secrets.env，并设置 chmod 600。

# 运行目录。中文：策略状态、机会、报告和只读快照写入 /var/lib，代码目录保持可替换。
ARB_RUNTIME_LIVE_ROOT=/var/lib/easy-arb/live
ARB_RUNTIME_LIVE_PREREQ_ROOT=/var/lib/easy-arb/live-prereq

# 生产服务不在 systemd（Linux 服务管理器）启动时构建二进制。
ARB_RUNTIME_LIVE_BUILD=0
ARB_RUNTIME_LIVE_BIN=/opt/easy-arb/current/target/release/arb-runtime
ARB_WALLET_SIGNER_PATH=/opt/easy-arb/current/target/release/arb-wallet-signer

# 服务器上还运行 Easy Tool。中文：Easy Tool runtime 默认使用 8787，
# 因此 Binance perp WSS 固定到 8806，避开 Easy Tool runtime 端口。
ARB_RUNTIME_LIVE_PORTFOLIO_BIND=127.0.0.1:8805
ARB_RUNTIME_LIVE_BINANCE_SPOT_WSS_BIND=127.0.0.1:8786
ARB_RUNTIME_LIVE_BINANCE_PERP_WSS_BIND=127.0.0.1:8806
ARB_RUNTIME_LIVE_BYBIT_SPOT_WSS_BIND=127.0.0.1:8788
ARB_RUNTIME_LIVE_BYBIT_PERP_WSS_BIND=127.0.0.1:8789
ARB_RUNTIME_LIVE_OKX_SPOT_WSS_BIND=127.0.0.1:8790
ARB_RUNTIME_LIVE_OKX_PERP_WSS_BIND=127.0.0.1:8791
ARB_RUNTIME_LIVE_BITGET_SPOT_WSS_BIND=127.0.0.1:8792
ARB_RUNTIME_LIVE_BITGET_PERP_WSS_BIND=127.0.0.1:8793
ARB_RUNTIME_LIVE_ASTER_PERP_WSS_BIND=127.0.0.1:8794
ARB_RUNTIME_LIVE_HYPERLIQUID_PERP_WSS_BIND=127.0.0.1:8795
ARB_RUNTIME_LIVE_TARGET_BINANCE_SPOT_WSS_BIND=127.0.0.1:8816
ARB_RUNTIME_LIVE_TARGET_BINANCE_PERP_WSS_BIND=127.0.0.1:8817
ARB_RUNTIME_LIVE_TARGET_BYBIT_SPOT_WSS_BIND=127.0.0.1:8818
ARB_RUNTIME_LIVE_TARGET_BYBIT_PERP_WSS_BIND=127.0.0.1:8819
ARB_RUNTIME_LIVE_TARGET_OKX_SPOT_WSS_BIND=127.0.0.1:8820
ARB_RUNTIME_LIVE_TARGET_OKX_PERP_WSS_BIND=127.0.0.1:8821
ARB_RUNTIME_LIVE_TARGET_BITGET_SPOT_WSS_BIND=127.0.0.1:8822
ARB_RUNTIME_LIVE_TARGET_BITGET_PERP_WSS_BIND=127.0.0.1:8823
BASIS_OBSERVER_TARGET_WSS_BASE_PORT=8830

# live 默认按策略解析订阅范围：spot-perp 取同交易所 spot/perp 交集，funding-arb 取跨两家以上交易所共有 perp。
# 需要强制全市场扫描时改成 all；需要手工列表时改成 custom 并设置各 ARB_RUNTIME_LIVE_*_WSS_SYMBOL。
ARB_RUNTIME_LIVE_CEX_WSS_SCOPE=auto
ARB_RUNTIME_LIVE_BINANCE_WSS_SYMBOL=ALL_USDT
ARB_RUNTIME_LIVE_BYBIT_WSS_SYMBOL=ALL_USDT
ARB_RUNTIME_LIVE_OKX_WSS_SYMBOL=ALL_USDT
ARB_RUNTIME_LIVE_BITGET_WSS_SYMBOL=ALL_USDT
ARB_RUNTIME_LIVE_ASTER_WSS_SYMBOL=ALL_USDT
ARB_RUNTIME_LIVE_HYPERLIQUID_WSS_SYMBOL=ALL_USDT
ARB_RUNTIME_LIVE_TARGET_WSS_ENABLED=1
ARB_RUNTIME_LIVE_WSS_READY_TIMEOUT_SECS=180
ARB_RUNTIME_LIVE_WSS_RECONNECT_DELAY_SECS=2

# 策略与风控。中文：默认小额、低并发，先保证同机稳定性。
BASIS_OBSERVER_CONFIG=templates/personal_guarded_live.preflight.yaml
BASIS_OBSERVER_STRATEGIES=spot-perp-basis,cross-exchange-funding-arb
BASIS_OBSERVER_MIN_NET_BPS=5
BASIS_OBSERVER_MIN_ABS_FUNDING_RATE=0
BASIS_OBSERVER_NOTIONAL_USD=100.00
BASIS_OBSERVER_SPOT_FEE_BPS=10
BASIS_OBSERVER_PERP_FEE_BPS=5
BASIS_OBSERVER_SLIPPAGE_BPS=5
BASIS_OBSERVER_AUTO_PRICE_GUARD_BPS=2
FUNDING_ARB_MAX_ENTRY_PRICE_DIVERGENCE_BPS=20

BASIS_OBSERVER_BASIS_RESIDENT_INTERVAL_SECS=60
BASIS_OBSERVER_BASIS_RESIDENT_MAX_LIVE_ENTRIES=1
BASIS_OBSERVER_BASIS_RESIDENT_MAX_CONCURRENT_POSITIONS=1
BASIS_OBSERVER_BASIS_RESIDENT_MAX_TOTAL_NOTIONAL_USDT=100.00

# 永续目标杠杆。中文：所有非 reduce-only 实盘开仓前会先设置目标杠杆；设置失败或无法确认时不下单。
BASIS_OBSERVER_PERP_TARGET_LEVERAGE=1
BASIS_OBSERVER_BINANCE_USDM_LEVERAGE=1
BASIS_OBSERVER_BYBIT_LINEAR_LEVERAGE=1
BASIS_OBSERVER_OKX_SWAP_LEVERAGE=1
BASIS_OBSERVER_BITGET_USDT_FUTURES_LEVERAGE=1
BASIS_OBSERVER_ASTER_PERP_LEVERAGE=1
BASIS_OBSERVER_HYPERLIQUID_PERP_LEVERAGE=1

BASIS_OBSERVER_FUNDING_ARB_MODE=resident
BASIS_OBSERVER_FUNDING_ARB_RESIDENT_INTERVAL_SECS=60
BASIS_OBSERVER_FUNDING_ARB_RESIDENT_MAX_LIVE_ENTRIES=1
BASIS_OBSERVER_FUNDING_ARB_RESIDENT_MAX_CYCLES=

# 日志与快照体积控制。中文：默认只在每轮 resident/canary 目录保留本轮相关 pair 的压缩快照；
# 如果排查全市场行级问题，可临时设为 0 恢复完整快照。
ARB_RUNTIME_FUNDING_ARB_COMPACT_ARTIFACTS=1
BASIS_OBSERVER_HEALTH_EVENT_SAMPLE_SECS=300
ARB_RUNTIME_JSONL_ROTATE_BYTES=134217728
ARB_RUNTIME_JSONL_ROTATE_KEEP=4

# 受限产品门禁。中文：tradfi_perp（传统金融永续）、stock_perp（股票永续）、
# commodity_perp（商品永续）和 pre_market_perp（盘前/未上市资产永续）默认不得 live 下单。
# 如果要交易这类产品，先由人工/只读预检生成确认文件，确认账户已开通、协议已接受、
# 地区允许、symbol（交易对）可交易，并设置有效 expires_at。
BASIS_OBSERVER_FUNDING_ARB_RESTRICTED_PRODUCT_PREFLIGHT=
BASIS_OBSERVER_TRADFI_PERP_SYMBOLS=
BASIS_OBSERVER_STOCK_PERP_SYMBOLS=
BASIS_OBSERVER_COMMODITY_PERP_SYMBOLS=
BASIS_OBSERVER_PRE_MARKET_PERP_SYMBOLS=

# 资金费率结算只读快照。中文：raw snapshot（原始快照）由运行时维护，不手工编辑。
BASIS_OBSERVER_FUNDING_SETTLEMENT_RAW_SNAPSHOT=/var/lib/easy-arb/live/private-readonly/funding_settlement_raw_snapshot.json
BASIS_OBSERVER_FUNDING_SETTLEMENT_LEDGER=

# portfolio JSON API（组合只读接口）默认从 resident root（常驻运行目录）自动发现快照。
# 可选覆盖组合私有只读采集交易所，逗号分隔；留空表示正式接入的 funding-arb 交易所。
# Gate/Lighter staged 交易所必须在只读凭证就绪后显式写入该列表，避免未知外部状态被误当成功。
ARB_RUNTIME_PORTFOLIO_PRIVATE_READONLY_VENUES=
ARB_RUNTIME_PORTFOLIO_ACCOUNT_SNAPSHOT=
ARB_RUNTIME_PORTFOLIO_POSITION_SNAPSHOT=
