{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://universal-arb-platform.local/schemas/candidate_portfolio_transition.schema.json",
  "title": "CandidatePortfolioTransition",
  "description": "Strategy output describing a proposed portfolio transformation, not an executable trade. 中文：策略只能输出候选组合状态转换，不能直接表达“立即执行”的命令。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transition_id",
    "strategy_id",
    "strategy_version",
    "code_version",
    "config_version",
    "created_at",
    "input_event_refs",
    "current_portfolio_state_ref",
    "holding_period",
    "legs",
    "expected_post_state_delta",
    "expected_economics",
    "required_capital",
    "failure_modes",
    "risk_flags",
    "assumptions"
  ],
  "properties": {
    "schema_version": {
      "$ref": "common.defs.schema.json#/$defs/Version"
    },
    "transition_id": {
      "$ref": "common.defs.schema.json#/$defs/Identifier"
    },
    "strategy_id": {
      "$ref": "common.defs.schema.json#/$defs/Identifier"
    },
    "strategy_version": {
      "$ref": "common.defs.schema.json#/$defs/Version"
    },
    "code_version": {
      "$ref": "common.defs.schema.json#/$defs/Version"
    },
    "config_version": {
      "$ref": "common.defs.schema.json#/$defs/Version"
    },
    "created_at": {
      "$ref": "common.defs.schema.json#/$defs/DateTime"
    },
    "input_event_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.defs.schema.json#/$defs/Identifier"
      },
      "description": "Events used by the strategy decision. 中文：策略决策实际读取的事件引用，用于回放和审计。"
    },
    "current_portfolio_state_ref": {
      "$ref": "common.defs.schema.json#/$defs/Identifier"
    },
    "holding_period": {
      "$ref": "#/$defs/HoldingPeriod"
    },
    "legs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/TransitionLeg"
      }
    },
    "expected_post_state_delta": {
      "$ref": "#/$defs/ExpectedPostStateDelta"
    },
    "expected_economics": {
      "$ref": "#/$defs/ExpectedEconomics"
    },
    "required_capital": {
      "$ref": "#/$defs/RequiredCapital"
    },
    "margin_impact": {
      "$ref": "#/$defs/ImpactBlock"
    },
    "inventory_impact": {
      "$ref": "#/$defs/ImpactBlock"
    },
    "liquidity_impact": {
      "$ref": "#/$defs/ImpactBlock"
    },
    "funding_impact": {
      "$ref": "#/$defs/ImpactBlock"
    },
    "borrow_lend_impact": {
      "$ref": "#/$defs/ImpactBlock"
    },
    "failure_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/FailureMode"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RiskFlag"
      },
      "uniqueItems": true
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Assumption"
      }
    }
  },
  "$defs": {
    "HoldingPeriod": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "enum": [
            "Instant",
            "Seconds",
            "Minutes",
            "Hours",
            "Days",
            "UntilFundingTimestamp",
            "UntilExpiry",
            "UntilBasisConvergence",
            "UntilManualExit"
          ],
          "description": "Holding period class. 中文：持仓周期类别，会影响资本预留、监控和退出策略。"
        },
        "duration_ms": {
          "$ref": "common.defs.schema.json#/$defs/DurationMs"
        },
        "until_timestamp": {
          "$ref": "common.defs.schema.json#/$defs/DateTime"
        },
        "exit_policy_ref": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        }
      }
    },
    "TransitionLeg": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "leg_id",
        "leg_type",
        "asset_flows",
        "constraints",
        "failure_modes"
      ],
      "properties": {
        "leg_id": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        },
        "leg_type": {
          "enum": [
            "Trade",
            "Transfer",
            "Borrow",
            "Lend",
            "Repay",
            "Bridge",
            "Hedge",
            "FundingCapture",
            "Observation"
          ],
          "description": "Semantic leg type, still not executable. 中文：候选动作的语义类型，真正执行动作由执行计划生成。"
        },
        "venue_id": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        },
        "instrument_id": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        },
        "account_id": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        },
        "side": {
          "enum": [
            "Buy",
            "Sell",
            "Long",
            "Short",
            "Deposit",
            "Withdraw",
            "Borrow",
            "Lend",
            "Repay",
            "Receive",
            "Pay",
            "None"
          ]
        },
        "asset_flows": {
          "type": "array",
          "items": {
            "$ref": "common.defs.schema.json#/$defs/AssetFlow"
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean"
            ]
          },
          "description": "Non-authoritative strategy constraints. 中文：策略建议的约束，必须由风控和执行管线重新校验。"
        },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/FailureMode"
          }
        }
      }
    },
    "ExpectedPostStateDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_flows",
        "position_deltas"
      ],
      "properties": {
        "asset_flows": {
          "type": "array",
          "items": {
            "$ref": "common.defs.schema.json#/$defs/AssetFlow"
          }
        },
        "position_deltas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PositionDelta"
          }
        },
        "reserve_deltas": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ReserveDelta"
          }
        }
      }
    },
    "PositionDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instrument_id",
        "quantity_delta"
      ],
      "properties": {
        "instrument_id": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        },
        "account_id": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        },
        "quantity_delta": {
          "$ref": "common.defs.schema.json#/$defs/DecimalString"
        }
      }
    },
    "ReserveDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "amount_delta"
      ],
      "properties": {
        "asset_id": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        },
        "amount_delta": {
          "$ref": "common.defs.schema.json#/$defs/DecimalString"
        }
      }
    },
    "ExpectedEconomics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_profit_usd",
        "expected_profit_bps",
        "fee_estimate_usd",
        "slippage_estimate_usd",
        "confidence"
      ],
      "properties": {
        "expected_profit_usd": {
          "$ref": "common.defs.schema.json#/$defs/DecimalString"
        },
        "expected_profit_bps": {
          "$ref": "common.defs.schema.json#/$defs/DecimalString"
        },
        "expected_apr": {
          "$ref": "common.defs.schema.json#/$defs/DecimalString"
        },
        "fee_estimate_usd": {
          "$ref": "common.defs.schema.json#/$defs/NonNegativeDecimalString"
        },
        "slippage_estimate_usd": {
          "$ref": "common.defs.schema.json#/$defs/NonNegativeDecimalString"
        },
        "gas_estimate_usd": {
          "$ref": "common.defs.schema.json#/$defs/NonNegativeDecimalString"
        },
        "confidence": {
          "$ref": "common.defs.schema.json#/$defs/Confidence"
        }
      }
    },
    "RequiredCapital": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_requirements",
        "recovery_buffer_usd"
      ],
      "properties": {
        "asset_requirements": {
          "type": "array",
          "items": {
            "$ref": "common.defs.schema.json#/$defs/AssetFlow"
          }
        },
        "recovery_buffer_usd": {
          "$ref": "common.defs.schema.json#/$defs/NonNegativeDecimalString"
        }
      }
    },
    "ImpactBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 512
        },
        "impact_usd": {
          "$ref": "common.defs.schema.json#/$defs/DecimalString"
        },
        "confidence": {
          "$ref": "common.defs.schema.json#/$defs/Confidence"
        }
      }
    },
    "FailureMode": {
      "enum": [
        "NoOpFailure",
        "RetryableFailure",
        "PartialFill",
        "LateFill",
        "DuplicateEvent",
        "UnknownState",
        "StuckTransaction",
        "VenueOutage",
        "RateLimit",
        "ManualInterventionRequired"
      ]
    },
    "RiskFlag": {
      "enum": [
        "StaleMarketData",
        "InsufficientLiquidity",
        "HighGas",
        "HighSlippage",
        "InventoryLimitExceeded",
        "MarginInsufficient",
        "LiquidationTooClose",
        "FundingRateUnstable",
        "BasisWidening",
        "VenueUnhealthy",
        "ChainCongested",
        "ApiRateLimited",
        "OneLegExecutionRisk",
        "OracleDivergence",
        "SettlementDelay",
        "CustodyRisk",
        "BridgeRisk",
        "ModelUncertainty",
        "UnknownState"
      ]
    },
    "Assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "statement",
        "confidence"
      ],
      "properties": {
        "assumption_id": {
          "$ref": "common.defs.schema.json#/$defs/Identifier"
        },
        "statement": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "description": "Human-readable assumption. 中文：人可读假设，只能作为补充说明，不能替代结构化字段。"
        },
        "confidence": {
          "$ref": "common.defs.schema.json#/$defs/Confidence"
        },
        "source_event_refs": {
          "type": "array",
          "items": {
            "$ref": "common.defs.schema.json#/$defs/Identifier"
          }
        }
      }
    }
  }
}
